# Template Dockerfile: Plex (LinuxServer) + Tiramisu.
# Build context must contain a ./src folder with this repo's contents.

FROM golang:1.24-bookworm AS build

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      build-essential \
      pkg-config \
      libfuse3-dev \
      ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src

COPY ./src/go.mod ./src/go.sum ./
COPY ./src/internal/anacrolix-torrent/go.mod ./internal/anacrolix-torrent/go.mod
COPY ./src/internal/anacrolix-torrent/go.sum ./internal/anacrolix-torrent/go.sum
RUN go mod download

COPY ./src/. ./

ARG APP_VERSION=dev

RUN CGO_ENABLED=1 GOOS=linux \
    go build -pgo=auto -ldflags "-X main.AppVersion=${APP_VERSION}" -o /out/tiramisu .


FROM lscr.io/linuxserver/plex:latest

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      fuse3 \
      iptables \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=build /out/tiramisu /usr/local/bin/tiramisu

# Windows bind mounts can drop execute bits, so bake the custom hook scripts in.
COPY ./custom-services /custom-services.d
COPY ./custom-cont-init /custom-cont-init.d
RUN chmod +x /custom-services.d/* /custom-cont-init.d/* || true
